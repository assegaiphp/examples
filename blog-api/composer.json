{
    "name": "assegaiphp/blog-api",
    "description": "A posts API with generated CRUD routes, DTO validation, API docs, and repository-backed persistence.",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Assegaiphp\\BlogApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Assegai\\Orm\\": "../../orm/src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:5000 bootstrap.php",
        "test": "vendor/bin/pest"
    },
    "license": "MIT",
    "authors": [],
    "require": {
        "assegaiphp/core": "dev-develop",
        "assegaiphp/orm": "dev-develop",
        "ext-curl": "*",
        "ext-pdo": "*",
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.4"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../core",
            "packages": [
                {
                    "name": "assegaiphp/core",
                    "version": "dev-develop",
                    "autoload": {
                        "psr-4": {
                            "Assegaiphp\\Core\\": "src/"
                        }
                    }
                },
                {
                    "name": "assegaiphp/orm",
                    "version": "dev-develop",
                    "autoload": {
                        "psr-4": {
                            "Assegaiphp\\Orm\\": "src/"
                        }
                    }
                }
            ]
        }
    ]
}
